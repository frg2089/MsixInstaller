<ui:FluentWindow
    x:Class="MsixInstaller.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MsixInstaller"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:res="clr-namespace:MsixInstaller.Resources"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="MainWindow"
    Width="652"
    Height="418"
    d:DataContext="{d:DesignInstance Type={x:Type local:MainWindowViewModel}}"
    Loaded="OnLoaded"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <ui:TitleBar Height="32" />

        <Grid Grid.Row="1" Margin="26,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:TextBlock Grid.Column="0" TextWrapping="Wrap">
                <Run FontSize="28" Text="{Binding Title, Mode=OneTime}" />
                <LineBreak />
                <Run Text="{Binding Publisher, Mode=OneTime}" />
                <LineBreak />
                <Run Text="{Binding Version, Mode=OneTime}" />
                <LineBreak />
                <Run Text="{Binding Path, Mode=OneTime}" />
            </ui:TextBlock>

            <ui:Image
                Grid.Column="1"
                Width="90"
                Height="90"
                HorizontalAlignment="Right"
                Source="{Binding Logo, Mode=OneTime}" />

            <Border
                Grid.Row="2"
                Grid.ColumnSpan="2"
                Margin="0,0,12,0"
                Padding="6"
                BorderThickness="3">
                <Border.BorderBrush>
                    <SolidColorBrush Color="{DynamicResource SystemAccentColor}" />
                </Border.BorderBrush>
                <ui:TextBlock Text="{Binding Subject, Mode=OneTime}" TextWrapping="WrapWithOverflow" />
            </Border>

        </Grid>

        <StackPanel
            Grid.Row="2"
            Margin="24,16"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <ui:Button
                Width="122"
                Height="32"
                VerticalContentAlignment="Center"
                Appearance="Primary"
                Background="{DynamicResource SystemAccentBrush}"
                Command="{Binding ConfirmCommand}"
                Content="{x:Static res:Resource.ConfirmText}"
                IsEnabled="{Binding EnabledButton}" />
            <ui:Button
                Width="122"
                Height="32"
                Margin="12,0"
                VerticalContentAlignment="Center"
                Appearance="Primary"
                Background="{DynamicResource SystemAccentBrush}"
                Command="{Binding CancelCommand}"
                Content="{x:Static res:Resource.CancelText}"
                IsEnabled="{Binding EnabledButton}" />
        </StackPanel>

        <Grid Grid.Row="3">
            <ui:Flyout IsOpen="{Binding FlyoutOpen, Mode=TwoWay}" Placement="Top">
                <ui:TextBlock Margin="24" TextWrapping="WrapWithOverflow">
                    <Run FontSize="24" Text="{x:Static res:Resource.About}" />
                    <LineBreak />
                    <Run FontSize="16" Text="{x:Static res:Resource.AppName}" />
                    <Run FontSize="16" Text="2.0.1.0" />
                    <LineBreak />
                    <Run FontSize="16" Text="{x:Static res:Resource.Copyright}" />
                </ui:TextBlock>
            </ui:Flyout>
            <ui:HyperlinkButton
                Margin="8"
                Padding="6"
                VerticalAlignment="Bottom"
                Command="{Binding OpenFlyoutCommand}"
                Foreground="{DynamicResource SystemAccentBrush}">
                <ui:SymbolIcon FontSize="26" Symbol="Info20" />
            </ui:HyperlinkButton>
        </Grid>
    </Grid>
</ui:FluentWindow>
